---
import { SITE, CATEGORIES } from '../site.config';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <a href="/" class="brand" aria-label={`${SITE.name} anasayfa`}>
        <picture>
          <source srcset="/parafomo-wordmark.webp" type="image/webp" />
          <img src="/parafomo-wordmark.png" alt={SITE.name} class="brand-logo" width="737" height="120" loading="lazy" />
        </picture>
      </a>
      <p class="soft">{SITE.tagline} Yatırım, borsa ve kişisel finansta sade ve güvenilir Türkçe rehber.</p>
      <div class="socials">
        {SITE.social.x && <a href={SITE.social.x} aria-label="X (Twitter)" rel="me noopener" target="_blank">X</a>}
        {SITE.social.instagram && <a href={SITE.social.instagram} aria-label="Instagram" rel="me noopener" target="_blank">Instagram</a>}
        <a href="/rss.xml" aria-label="RSS akışı">RSS</a>
      </div>
    </div>

    <nav class="footer-col" aria-label="Kategoriler">
      <h3>Kategoriler</h3>
      {CATEGORIES.map((c) => (
        <a href={`/kategori/${c.slug}`}>{c.name}</a>
      ))}
    </nav>

    <nav class="footer-col" aria-label="Site">
      <h3>Site</h3>
      <a href="/blog">Tüm Yazılar</a>
      <a href="/hakkimizda">Hakkımızda</a>
      <a href="/rss.xml">RSS</a>
      <a href={`mailto:${SITE.email}`}>İletişim</a>
    </nav>
  </div>

  <div class="container footer-bottom">
    <p class="muted">© {year} {SITE.name}. Tüm hakları saklıdır.</p>
    <p class="muted disclaimer">
      Bu sitedeki içerikler yalnızca bilgilendirme amaçlıdır, yatırım tavsiyesi değildir.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 5rem;
    border-top: 1px solid var(--border-soft);
    background: var(--bg-elev);
    padding-top: 3.5rem;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: 2.5rem;
    padding-bottom: 2.5rem;
  }
  .footer-brand .brand { display: inline-flex; align-items: center; margin-bottom: 0.9rem; }
  .brand-logo { height: 28px; width: auto; display: block; }
  .footer-brand p { max-width: 34ch; font-size: var(--step--1); }

  .socials { display: flex; gap: 0.5rem; margin-top: 1rem; }
  .socials a {
    font-size: var(--step--1);
    font-weight: 600;
    padding: 0.4rem 0.8rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--text-soft);
  }
  .socials a:hover { border-color: var(--brand); color: var(--brand); }

  .footer-col { display: flex; flex-direction: column; gap: 0.6rem; }
  .footer-col h3 { font-family: var(--font-sans); font-size: var(--step--1); text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); margin-bottom: 0.4rem; }
  .footer-col a { color: var(--text-soft); font-size: var(--step--1); }
  .footer-col a:hover { color: var(--brand); }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    padding: 1.4rem 0 2.5rem;
    border-top: 1px solid var(--border-soft);
    font-size: var(--step--1);
  }
  .disclaimer { max-width: 48ch; }

  @media (max-width: 760px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
    .footer-brand { grid-column: 1 / -1; }
  }
</style>
