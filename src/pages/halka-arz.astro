---
import BaseLayout from '../layouts/BaseLayout.astro';
import Newsletter from '../components/Newsletter.astro';
import data from '../../data/halka-arz.json';

type IPO = {
  company: string;
  bist_code: string;
  slug: string;
  link: string;
  date_text: string;
  start: string | null;
  end: string | null;
  status: string;
  price: string;
  distribution: string;
  lot: string;
  broker: string;
};

const items = (data.items ?? []) as IPO[];
const by = (s: string) => items.filter((i) => i.status === s);

const ongoing = by('Devam Ediyor');
const upcoming = by('Yaklaşan');
const pending = by('Tarih Bekleniyor');
const completed = by('Tamamlandı');

const updated = new Date(data.updated).toLocaleDateString('tr-TR', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const stats = [
  { n: ongoing.length, label: 'Talep toplanıyor' },
  { n: upcoming.length, label: 'Yaklaşan' },
  { n: pending.length, label: 'Tarih bekleyen' },
  { n: completed.length, label: 'Son tamamlanan' },
].filter((s) => s.n > 0);

// Kart olarak gösterilecek gruplar (tarih bekleyenler ayrı, çip listesi olarak).
const cardGroups = [
  { title: 'Talep Toplanıyor', desc: 'Şu anda halka arzı devam eden şirketler.', list: ongoing, tone: 'live', live: true },
  { title: 'Yaklaşan Halka Arzlar', desc: 'Tarihi açıklanmış, talep toplamayı bekleyenler.', list: upcoming, tone: 'soon', live: false },
  { title: 'Son Tamamlananlar', desc: 'Yakın zamanda işlem görmeye başlayan halka arzlar.', list: completed, tone: 'done', live: false },
].filter((g) => g.list.length > 0);
---

<BaseLayout
  title="BIST Halka Arz Takvimi"
  description="Borsa İstanbul (BIST) güncel halka arz takvimi: talep toplanan, yaklaşan ve son tamamlanan halka arzlar — tarih, fiyat, lot ve aracı kurum bilgisiyle. Her gün güncellenir."
>
  <section class="container ha-hero">
    <span class="eyebrow"><span class="pulse"></span> Borsa İstanbul · Canlı takvim</span>
    <h1>Halka Arz Takvimi</h1>
    <p class="lede soft">
      BIST’te talep toplanan, yaklaşan ve son tamamlanan halka arzlar — tarih, fiyat,
      dağıtım yöntemi ve aracı kurum bilgileriyle tek sayfada. Her gün otomatik güncellenir.
    </p>

    {stats.length > 0 && (
      <div class="ha-stats">
        {stats.map((s) => (
          <div class="ha-stat">
            <strong>{s.n}</strong>
            <span>{s.label}</span>
          </div>
        ))}
        <div class="ha-stat ha-stat-upd">
          <strong>{updated}</strong>
          <span>Son güncelleme</span>
        </div>
      </div>
    )}
  </section>

  {cardGroups.map((g) => (
    <section class="container ha-section">
      <div class="ha-shead">
        <h2>{g.title}</h2>
        <span class="ha-shead-count">{g.list.length}</span>
        <p class="soft">{g.desc}</p>
      </div>

      <div class="ha-grid">
        {g.list.map((i) => (
          <a class={`ha-card tone-${g.tone}`} href={i.link} target="_blank" rel="noopener">
            <div class="ha-card-head">
              <h3 class="ha-name">{i.company}</h3>
              {i.bist_code && <span class="ha-code">{i.bist_code}</span>}
            </div>

            {(i.date_text || g.live) && (
              <div class="ha-date">
                {g.live && <span class="ha-live">CANLI</span>}
                {i.date_text && <span>{i.date_text}</span>}
              </div>
            )}

            <dl class="ha-meta">
              {i.price && (<div><dt>Fiyat</dt><dd class="ha-price">{i.price}</dd></div>)}
              {i.lot && (<div><dt>Pay</dt><dd>{i.lot}</dd></div>)}
              {i.distribution && (<div><dt>Dağıtım</dt><dd>{i.distribution}</dd></div>)}
              {i.broker && (<div><dt>Aracı kurum</dt><dd class="ha-broker">{i.broker}</dd></div>)}
            </dl>

            <span class="ha-go">Detay →</span>
          </a>
        ))}
      </div>
    </section>
  ))}

  {pending.length > 0 && (
    <section class="container ha-section">
      <div class="ha-shead">
        <h2>Tarih Bekleyenler</h2>
        <span class="ha-shead-count">{pending.length}</span>
        <p class="soft">Başvurusu yapılmış, talep toplama tarihi henüz açıklanmamış şirketler.</p>
      </div>
      <div class="ha-chips">
        {pending.map((i) => (
          <a class="ha-chip" href={i.link} target="_blank" rel="noopener">
            <span class="ha-chip-name">{i.company}</span>
            {i.bist_code && <span class="ha-chip-code">{i.bist_code}</span>}
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="container ha-note">
    <p>
      Veriler <a href={data.source_url} target="_blank" rel="noopener">{data.source}</a> kaynağından
      derlenir ve günlük güncellenir. Bu sayfa yalnızca bilgilendirme amaçlıdır; yatırım
      tavsiyesi değildir. Kesin tarih, fiyat ve koşullar için izahname ve KAP duyurularını esas alın.
    </p>
  </section>

  <div class="container">
    <Newsletter />
  </div>
</BaseLayout>

<style>
  /* ---------- Hero ---------- */
  .ha-hero { padding: clamp(2rem, 5vw, 3.5rem) 0 0; max-width: 820px; }
  .eyebrow { display: inline-flex; align-items: center; gap: 0.5rem; font-size: var(--step--1); font-weight: 600; color: var(--brand); }
  .pulse { width: 8px; height: 8px; border-radius: 50%; background: var(--brand); box-shadow: 0 0 0 0 rgba(22,160,133,0.5); animation: pulse 2s infinite; }
  @keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(22,160,133,0.5); } 70% { box-shadow: 0 0 0 7px rgba(22,160,133,0); } 100% { box-shadow: 0 0 0 0 rgba(22,160,133,0); } }
  .ha-hero h1 { font-size: var(--step-4); margin: 0.9rem 0 0.6rem; }
  .ha-hero .lede { font-size: var(--step-1); line-height: 1.55; }

  .ha-stats { display: flex; flex-wrap: wrap; gap: 0; margin-top: 2rem; border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; background: var(--bg-card); box-shadow: var(--shadow-xs); }
  .ha-stat { flex: 1 1 0; min-width: 120px; padding: 1rem 1.2rem; border-right: 1px solid var(--border-soft); }
  .ha-stat:last-child { border-right: none; }
  .ha-stat strong { display: block; font-family: var(--font-serif); font-size: var(--step-2); color: var(--text); line-height: 1.1; }
  .ha-stat span { font-size: var(--step--2); color: var(--text-muted); }
  .ha-stat-upd { background: var(--bg-elev); }
  .ha-stat-upd strong { font-size: var(--step-0); color: var(--brand-deep); }

  /* ---------- Section header ---------- */
  .ha-section { margin-top: clamp(2.5rem, 6vw, 4rem); }
  .ha-shead { display: grid; grid-template-columns: auto auto 1fr; align-items: center; gap: 0.7rem; margin-bottom: 1.4rem; }
  .ha-shead h2 { font-size: var(--step-2); margin: 0; }
  .ha-shead-count { justify-self: start; font-size: var(--step--2); font-weight: 700; color: var(--brand-deep); background: var(--brand-tint); border-radius: 999px; padding: 0.15rem 0.6rem; }
  .ha-shead p { grid-column: 1 / -1; font-size: var(--step--1); margin: 0; }

  /* ---------- Cards ---------- */
  .ha-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.2rem; }
  .ha-card {
    display: flex; flex-direction: column;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.3rem 1.4rem 1.1rem;
    text-decoration: none; color: inherit;
    box-shadow: var(--shadow-xs);
    position: relative;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }
  .ha-card::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; border-radius: var(--radius) 0 0 var(--radius); background: var(--border); }
  .ha-card.tone-live::before { background: linear-gradient(var(--brand), var(--brand-light)); }
  .ha-card.tone-soon::before { background: #e0a83a; }
  .ha-card.tone-done::before { background: var(--border); }
  .ha-card:hover { transform: translateY(-3px); box-shadow: var(--shadow); border-color: var(--brand-light); }
  .ha-card.tone-done { opacity: 0.94; }

  .ha-card-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 0.6rem; margin-bottom: 0.7rem; }
  .ha-name { font-family: var(--font-serif); font-weight: 600; font-size: var(--step-1); line-height: 1.25; margin: 0; color: var(--text); }
  .ha-code { flex: none; font-size: var(--step--2); font-weight: 700; letter-spacing: 0.04em; color: var(--brand-deep); background: var(--brand-tint); border-radius: var(--radius-sm); padding: 0.2rem 0.55rem; white-space: nowrap; }

  .ha-date { display: flex; align-items: center; gap: 0.5rem; font-size: var(--step--1); font-weight: 600; color: var(--brand-deep); margin-bottom: 0.9rem; flex-wrap: wrap; }
  .ha-live { font-size: 0.62rem; font-weight: 800; letter-spacing: 0.08em; color: #fff; background: var(--brand); border-radius: 999px; padding: 0.15rem 0.5rem; }

  .ha-meta { margin: 0; border-top: 1px solid var(--border-soft); padding-top: 0.7rem; }
  .ha-meta > div { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; padding: 0.3rem 0; }
  .ha-meta dt { font-size: var(--step--2); color: var(--text-muted); flex: none; }
  .ha-meta dd { font-size: var(--step--1); margin: 0; color: var(--text-soft); text-align: right; }
  .ha-meta .ha-price { font-weight: 700; color: var(--text); font-size: var(--step-0); }
  .ha-meta .ha-broker { font-size: var(--step--2); }

  .ha-go { margin-top: 0.9rem; font-size: var(--step--1); font-weight: 600; color: var(--brand); }
  .ha-card:hover .ha-go { text-decoration: underline; }

  /* ---------- Pending chips ---------- */
  .ha-chips { display: flex; flex-wrap: wrap; gap: 0.6rem; }
  .ha-chip {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 999px; padding: 0.45rem 0.5rem 0.45rem 0.9rem;
    font-size: var(--step--1); color: var(--text-soft); text-decoration: none;
    transition: border-color 0.16s ease, color 0.16s ease, background 0.16s ease;
  }
  .ha-chip:hover { border-color: var(--brand-light); color: var(--text); background: var(--bg-elev); }
  .ha-chip-name { font-weight: 500; }
  .ha-chip-code { font-size: var(--step--2); font-weight: 700; color: var(--brand-deep); background: var(--brand-tint); border-radius: 999px; padding: 0.1rem 0.5rem; }

  /* ---------- Note ---------- */
  .ha-note { margin-top: clamp(2.5rem, 6vw, 4rem); }
  .ha-note p { font-size: var(--step--1); line-height: 1.65; max-width: 760px; color: var(--text-muted); padding: 1rem 1.2rem; background: var(--bg-elev); border: 1px solid var(--border-soft); border-radius: var(--radius); }
  .ha-note a { color: var(--brand); font-weight: 600; }

  @media (max-width: 600px) {
    .ha-stat { flex-basis: 50%; min-width: 0; }
  }
</style>
