---
import BaseLayout from '../layouts/BaseLayout.astro';
import Newsletter from '../components/Newsletter.astro';
import data from '../../data/halka-arz.json';

type IPO = {
  company: string; bist_code: string; slug: string; link: string;
  date_text: string; start: string | null; end: string | null;
  status: string; price: string; distribution: string; lot: string; broker: string;
};

const items = (data.items ?? []) as IPO[];
const by = (s: string) => items.filter((i) => i.status === s);
const pending = by('Tarih Bekleniyor');
const completed = by('Tamamlandı');

const updated = new Date(data.updated).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' });

const MONTHS = ['Ocak', 'Şubat', 'Mart', 'Nisan', 'Mayıs', 'Haziran', 'Temmuz', 'Ağustos', 'Eylül', 'Ekim', 'Kasım', 'Aralık'];
const DOW = ['Pzt', 'Sal', 'Çar', 'Per', 'Cum', 'Cmt', 'Paz'];
const pad = (n: number) => String(n).padStart(2, '0');

// aktif → yeşil, yaklaşan → sarı, geçmiş/tamamlanmış → kırmızı
const toneOf = (s: string) => (s === 'Devam Ediyor' ? 'live' : s === 'Yaklaşan' ? 'soon' : 'past');

// Tarihli halka arzları gün gün haritaya yerleştir.
const dated = items.filter((i) => i.start) as (IPO & { start: string })[];
const eventsByDay = new Map<string, IPO[]>();
for (const i of dated) {
  const s = new Date(i.start + 'T00:00:00');
  const e = new Date((i.end || i.start) + 'T00:00:00');
  for (let dt = new Date(s); dt <= e; dt.setDate(dt.getDate() + 1)) {
    const key = `${dt.getFullYear()}-${pad(dt.getMonth() + 1)}-${pad(dt.getDate())}`;
    if (!eventsByDay.has(key)) eventsByDay.set(key, []);
    eventsByDay.get(key)!.push(i);
  }
}

// SADECE bu ay — günler satır satır.
const today = new Date();
const y = today.getFullYear();
const m0 = today.getMonth();
const todayKey = `${y}-${pad(m0 + 1)}-${pad(today.getDate())}`;
const monthLabel = `${MONTHS[m0]} ${y}`;
const daysInMonth = new Date(y, m0 + 1, 0).getDate();
const days = Array.from({ length: daysInMonth }, (_, idx) => {
  const d = idx + 1;
  const dk = `${y}-${pad(m0 + 1)}-${pad(d)}`;
  const dow = (new Date(y, m0, d).getDay() + 6) % 7;
  // Geçmiş günde yine bir etkinlik varsa kırmızıya zorla.
  const evs = (eventsByDay.get(dk) ?? []).map((e) => ({
    ...e,
    tone: dk < todayKey ? 'past' : toneOf(e.status),
  }));
  return { d, dow: DOW[dow], isWeekend: dow >= 5, key: dk, isToday: dk === todayKey, isPast: dk < todayKey, events: evs };
});
---

<BaseLayout
  title="BIST Halka Arz Takvimi"
  description="Borsa İstanbul (BIST) bu ayki halka arz takvimi: talep toplama günleri, yaklaşanlar ve son tamamlananlar. Her gün otomatik güncellenir."
>
  <section class="container ha-hero">
    <span class="eyebrow"><span class="pulse"></span> Borsa İstanbul</span>
    <h1>Halka Arz Takvimi</h1>
    <p class="lede soft">{monthLabel} ayının halka arz takvimi. Her gün otomatik güncellenir.</p>
    <p class="ha-upd">Son güncelleme: {updated}</p>
  </section>

  <section class="container ha-section">
    <div class="cal-legend">
      <span><i class="dot live"></i> Talep toplanıyor</span>
      <span><i class="dot soon"></i> Yaklaşan</span>
      <span><i class="dot past"></i> Tarihi geçti</span>
    </div>

    <div class="cal-month">
      <div class="cal-month-title">{monthLabel}</div>
      <ul class="cal-list">
        {days.map((day) => (
          <li class:list={['cal-row', { today: day.isToday, past: day.isPast, weekend: day.isWeekend, empty: day.events.length === 0 }]}>
            <div class="cal-d">
              <span class="cal-num">{day.d}</span>
              <span class="cal-dow">{day.dow}</span>
              {day.isToday && <span class="cal-bugun">bugün</span>}
            </div>
            <div class="cal-ev-wrap">
              {day.events.length === 0
                ? <span class="cal-none">—</span>
                : day.events.map((e) => (
                    <a class={`cal-ev tone-${e.tone}`} href={e.link} target="_blank" rel="noopener" title={`${e.company} — ${e.date_text}`}>
                      <span class="cal-ev-name">{e.company}</span>
                      {e.bist_code && <span class="cal-ev-code">{e.bist_code}</span>}
                    </a>
                  ))}
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {pending.length > 0 && (
    <section class="container ha-section">
      <div class="ha-shead"><h2>Tarih Bekleyenler</h2><span class="ha-shead-count">{pending.length}</span></div>
      <div class="ha-chips">
        {pending.map((i) => (
          <a class="ha-chip" href={i.link} target="_blank" rel="noopener">
            <span>{i.company}</span>
            {i.bist_code && <span class="ha-chip-code">{i.bist_code}</span>}
          </a>
        ))}
      </div>
    </section>
  )}

  {completed.length > 0 && (
    <section class="container ha-section">
      <div class="ha-shead"><h2>Son Tamamlananlar</h2><span class="ha-shead-count">{completed.length}</span></div>
      <ul class="ha-done-list">
        {completed.map((i) => (
          <li>
            <a href={i.link} target="_blank" rel="noopener">
              <span class="dl-name">{i.company}</span>
              {i.bist_code && <span class="dl-code">{i.bist_code}</span>}
              <span class="dl-date">{i.date_text}</span>
              {i.price && <span class="dl-price">{i.price}</span>}
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <section class="container ha-note">
    <p>
      Veriler <a href={data.source_url} target="_blank" rel="noopener">{data.source}</a> kaynağından
      derlenir ve günde birkaç kez güncellenir. Yalnızca bilgilendirme amaçlıdır; yatırım tavsiyesi
      değildir. Kesin tarih, fiyat ve koşullar için izahname ve KAP duyurularını esas alın.
    </p>
  </section>

  <div class="container"><Newsletter /></div>
</BaseLayout>

<style>
  /* ---------- Hero ---------- */
  .ha-hero { padding: clamp(1.6rem, 4vw, 2.6rem) 0 0; max-width: 720px; }
  .eyebrow { display: inline-flex; align-items: center; gap: 0.45rem; font-size: var(--step--2); font-weight: 600; color: var(--brand); }
  .pulse { width: 7px; height: 7px; border-radius: 50%; background: var(--brand); box-shadow: 0 0 0 0 rgba(22,160,133,0.5); animation: pulse 2s infinite; }
  @keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(22,160,133,0.5); } 70% { box-shadow: 0 0 0 6px rgba(22,160,133,0); } 100% { box-shadow: 0 0 0 0 rgba(22,160,133,0); } }
  .ha-hero h1 { font-size: var(--step-2); margin: 0.6rem 0 0.4rem; }
  .ha-hero .lede { font-size: var(--step-0); line-height: 1.5; margin: 0; }
  .ha-upd { font-size: var(--step--2); color: var(--text-muted); margin: 0.5rem 0 0; }

  .ha-section { margin-top: clamp(1.6rem, 4vw, 2.6rem); }
  .ha-shead { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.9rem; }
  .ha-shead h2 { font-size: var(--step-1); margin: 0; }
  .ha-shead-count { font-size: 0.66rem; font-weight: 700; color: var(--brand-deep); background: var(--brand-tint); border-radius: 999px; padding: 0.1rem 0.55rem; }

  /* ---------- Legend ---------- */
  .cal-legend { display: flex; flex-wrap: wrap; gap: 1rem; margin-bottom: 0.9rem; font-size: var(--step--2); color: var(--text-muted); }
  .cal-legend span { display: inline-flex; align-items: center; gap: 0.4rem; }
  .cal-legend .dot { width: 9px; height: 9px; border-radius: 3px; display: inline-block; }
  .dot.live { background: var(--brand); }
  .dot.soon { background: #d8982f; }
  .dot.past { background: var(--danger); }

  /* ---------- Month list (günler satır satır) ---------- */
  .cal-month { border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; background: var(--bg-card); box-shadow: var(--shadow-xs); max-width: 640px; }
  .cal-month-title { font-family: var(--font-serif); font-weight: 600; font-size: var(--step-0); padding: 0.7rem 1rem; border-bottom: 1px solid var(--border); background: var(--bg-elev); }
  .cal-list { list-style: none; margin: 0; padding: 0; }
  .cal-row { display: grid; grid-template-columns: 56px 1fr; align-items: center; gap: 0.7rem; padding: 0.3rem 0.9rem; border-bottom: 1px solid var(--border-soft); border-left: 3px solid transparent; min-height: 34px; }
  .cal-row:last-child { border-bottom: none; }
  .cal-row.empty { opacity: 0.55; }
  .cal-row.weekend.empty { background: var(--bg-elev); }
  .cal-row.today { border-left-color: var(--brand-deep); background: var(--brand-tint); }

  .cal-d { display: flex; align-items: baseline; gap: 0.35rem; }
  .cal-num { font-size: var(--step--1); font-weight: 700; color: var(--text); font-variant-numeric: tabular-nums; min-width: 1.1em; text-align: right; }
  .cal-dow { font-size: 0.62rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.03em; }
  .cal-bugun { font-size: 0.56rem; font-weight: 700; color: #fff; background: var(--brand-deep); border-radius: 999px; padding: 0.05rem 0.35rem; text-transform: uppercase; letter-spacing: 0.04em; }
  .cal-row.empty .cal-num { color: var(--text-muted); font-weight: 600; }

  .cal-ev-wrap { display: flex; flex-wrap: wrap; gap: 0.35rem; }
  .cal-none { color: var(--text-muted); font-size: var(--step--2); opacity: 0.6; }
  .cal-ev { display: inline-flex; align-items: center; gap: 0.4rem; text-decoration: none; border-radius: 6px; padding: 0.2rem 0.5rem; font-size: var(--step--2); font-weight: 600; line-height: 1.3; border: 1px solid transparent; }
  .cal-ev-name { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 14rem; }
  .cal-ev-code { font-size: 0.6rem; font-weight: 800; letter-spacing: 0.03em; padding: 0.02rem 0.3rem; border-radius: 4px; background: rgba(255,255,255,0.45); }
  .cal-ev.tone-live { background: var(--brand); color: #fff; }
  .cal-ev.tone-soon { background: #fbf0d8; color: #8a5a12; border-color: #eccf94; }
  .cal-ev.tone-soon .cal-ev-code { background: #f0dcb0; }
  .cal-ev.tone-past { background: #fbe3e6; color: #a32437; border-color: #f1bcc3; }
  .cal-ev.tone-past .cal-ev-code { background: #f3ccd1; }
  .cal-ev:hover { filter: brightness(0.97); }

  /* ---------- Pending chips ---------- */
  .ha-chips { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .ha-chip { display: inline-flex; align-items: center; gap: 0.45rem; background: var(--bg-card); border: 1px solid var(--border); border-radius: 999px; padding: 0.35rem 0.45rem 0.35rem 0.8rem; font-size: var(--step--2); color: var(--text-soft); text-decoration: none; transition: border-color 0.16s ease, background 0.16s ease; }
  .ha-chip:hover { border-color: var(--brand-light); background: var(--bg-elev); }
  .ha-chip-code { font-size: 0.6rem; font-weight: 700; color: var(--brand-deep); background: var(--brand-tint); border-radius: 999px; padding: 0.08rem 0.45rem; }

  /* ---------- Completed list ---------- */
  .ha-done-list { list-style: none; padding: 0; margin: 0; border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; background: var(--bg-card); max-width: 640px; }
  .ha-done-list li { border-bottom: 1px solid var(--border-soft); }
  .ha-done-list li:last-child { border-bottom: none; }
  .ha-done-list a { display: grid; grid-template-columns: 1fr auto auto auto; align-items: center; gap: 0.7rem; padding: 0.55rem 0.9rem; text-decoration: none; color: var(--text-soft); font-size: var(--step--2); }
  .ha-done-list a:hover { background: var(--bg-elev); }
  .dl-name { color: var(--text); font-weight: 600; }
  .dl-code { font-size: 0.6rem; font-weight: 700; color: var(--brand-deep); background: var(--brand-tint); border-radius: 999px; padding: 0.08rem 0.45rem; }
  .dl-date { color: var(--text-muted); }
  .dl-price { font-weight: 700; color: var(--text); }

  /* ---------- Note ---------- */
  .ha-note { margin-top: clamp(1.6rem, 4vw, 2.6rem); }
  .ha-note p { font-size: var(--step--2); line-height: 1.6; max-width: 640px; color: var(--text-muted); padding: 0.8rem 1rem; background: var(--bg-elev); border: 1px solid var(--border-soft); border-radius: var(--radius); }
  .ha-note a { color: var(--brand); font-weight: 600; }

  @media (max-width: 560px) {
    .cal-ev-name { max-width: 9rem; }
    .ha-done-list a { grid-template-columns: 1fr auto; row-gap: 0.15rem; }
    .dl-date { grid-column: 1 / -1; }
  }
</style>

<script define:vars={{ built: data.updated }}>
  // Veri (cron ile) değiştiğinde açık sayfa kendini yeniler.
  async function checkUpdate() {
    try {
      const r = await fetch('/halka-arz.json?_=' + Date.now(), { cache: 'no-store' });
      const d = await r.json();
      if (d && d.updated && d.updated !== built) location.reload();
    } catch { /* yoksay */ }
  }
  setInterval(() => { if (document.visibilityState === 'visible') checkUpdate(); }, 300000);
</script>
