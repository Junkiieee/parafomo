---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import Newsletter from '../components/Newsletter.astro';
import { CATEGORIES, SITE } from '../site.config';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const featured = posts.find((p) => p.data.featured) ?? posts[0];
const rest = posts.filter((p) => p.id !== featured?.id).slice(0, 6);
const postCount = posts.length;
---

<BaseLayout>
  <!-- HERO -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <span class="eyebrow"><span class="pulse"></span> Bağımsız finans yayını</span>
        <h1>Parana <span class="accent">akıl</span> kat.</h1>
        <p class="lede soft">
          Yatırım, borsa, kripto ve kişisel finans… Karmaşık konuları sade ve uygulanabilir
          rehberlere çeviriyoruz. Reklam yok, taraf yok — sadece paranı korumana ve
          büyütmene yardım eden net bilgi.
        </p>
        <div class="hero-cta">
          <a href="/blog" class="btn btn-primary">Yazıları Keşfet</a>
          <a href="/hakkimizda" class="btn btn-ghost">Bizi Tanı</a>
        </div>
        <div class="hero-stats">
          <div><strong>{postCount}+</strong><span class="muted">Derinlemesine rehber</span></div>
          <div><strong>6</strong><span class="muted">Konu başlığı</span></div>
          <div><strong>%100</strong><span class="muted">Bağımsız içerik</span></div>
        </div>
      </div>
      <div class="hero-visual">
        <div class="ticker-card" id="ticker">
          <div class="tc-row" data-row="bist"><span>BIST 100</span><span class="tc-val"><b data-val>—</b><i class="chg" data-chg></i></span></div>
          <div class="tc-row" data-row="btc"><span>Bitcoin</span><span class="tc-val"><b data-val>—</b><i class="chg" data-chg></i></span></div>
          <div class="tc-row" data-row="gold"><span>Gram Altın</span><span class="tc-val"><b data-val>—</b><i class="chg" data-chg></i></span></div>
          <div class="tc-row" data-row="usd"><span>Dolar/TL</span><span class="tc-val"><b data-val>—</b><i class="chg" data-chg></i></span></div>
          <div class="tc-foot"><span class="muted">Son 24 saat değişimi</span><span data-updated class="muted"></span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURED -->
  {featured && (
    <section class="container section">
      <div class="section-head">
        <h2>Öne Çıkan</h2>
        <a href="/blog" class="muted-link">Tümü →</a>
      </div>
      <PostCard post={featured} featured />
    </section>
  )}

  <!-- CATEGORIES -->
  <section class="container section">
    <div class="section-head"><h2>Konular</h2></div>
    <div class="cat-grid">
      {CATEGORIES.map((c) => (
        <a href={`/kategori/${c.slug}`} class="cat-card card">
          <h3>{c.name}</h3>
          <p class="soft">{c.desc}</p>
          <span class="cat-go">Keşfet →</span>
        </a>
      ))}
    </div>
  </section>

  <!-- LATEST -->
  {rest.length > 0 && (
    <section class="container section">
      <div class="section-head">
        <h2>Son Yazılar</h2>
        <a href="/blog" class="muted-link">Tümü →</a>
      </div>
      <div class="post-grid">
        {rest.map((p) => <PostCard post={p} />)}
      </div>
    </section>
  )}

  <div class="container">
    <Newsletter />
  </div>
</BaseLayout>

<style>
  .hero { padding: clamp(2.5rem, 6vw, 5rem) 0 2rem; position: relative; }
  .hero-inner { display: grid; grid-template-columns: 1.15fr 0.85fr; gap: 3rem; align-items: center; }
  .pulse { width: 8px; height: 8px; border-radius: 50%; background: var(--brand); box-shadow: 0 0 0 0 var(--brand); animation: pulse 2s infinite; }
  @keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(43,177,148,0.5); } 70% { box-shadow: 0 0 0 8px rgba(43,177,148,0); } 100% { box-shadow: 0 0 0 0 rgba(43,177,148,0); } }
  .hero-text h1 { font-size: var(--step-4); margin: 1rem 0 1rem; }
  .accent { color: var(--brand); }
  .hero-text .lede { font-size: var(--step-1); max-width: 52ch; line-height: 1.55; }
  .hero-cta { display: flex; gap: 0.8rem; margin: 1.8rem 0 2rem; flex-wrap: wrap; }
  .hero-stats { display: flex; gap: 2.2rem; flex-wrap: wrap; padding-top: 1.5rem; border-top: 1px solid var(--border-soft); }
  .hero-stats strong { display: block; font-family: var(--font-serif); font-size: var(--step-2); color: var(--text); }
  .hero-stats span { font-size: var(--step--1); }

  .hero-visual { display: flex; justify-content: center; }
  .ticker-card {
    width: 100%; max-width: 360px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.4rem;
    box-shadow: var(--shadow-soft);
  }
  .tc-row { display: flex; justify-content: space-between; padding: 0.65rem 0; border-bottom: 1px solid var(--border-soft); font-size: var(--step--1); }
  .tc-row span:first-child { color: var(--text-soft); }
  .tc-val { display: flex; align-items: baseline; gap: 0.5rem; }
  .tc-val b { font-variant-numeric: tabular-nums; font-weight: 600; color: var(--text); }
  .chg { font-size: var(--step--2); font-weight: 600; font-style: normal; }
  .chg:empty::before { content: ''; }
  .up { color: var(--brand); font-weight: 600; }
  .down { color: var(--danger); font-weight: 600; }
  .tc-row:last-of-type { border-bottom: none; }
  .tc-foot { display: flex; justify-content: space-between; font-size: var(--step--2); color: var(--text-muted); margin-top: 0.9rem; padding-top: 0.7rem; border-top: 1px solid var(--border-soft); }

  .section { margin-top: clamp(3rem, 7vw, 5rem); }
  .section-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 1.5rem; }
  .section-head h2 { font-size: var(--step-2); margin: 0; }
  .muted-link { color: var(--text-muted); font-size: var(--step--1); font-weight: 600; }
  .muted-link:hover { color: var(--brand); }

  .cat-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 1.1rem; }
  .cat-card { padding: 1.4rem 1.4rem 1.5rem; display: flex; flex-direction: column; gap: 0.4rem; }
  .cat-card h3 { font-size: var(--step-1); margin: 0; color: var(--text); }
  .cat-card p { font-size: var(--step--1); margin: 0; flex: 1; }
  .cat-go { font-size: var(--step--1); font-weight: 600; color: var(--brand); margin-top: 0.6rem; }

  .post-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(290px, 1fr)); gap: 1.4rem; }

  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero-visual { order: -1; }
    .ticker-card { max-width: 100%; }
  }
</style>

<script>
  const fmt = (n: number, d = 0) =>
    n.toLocaleString('tr-TR', { minimumFractionDigits: d, maximumFractionDigits: d });

  // Büyük değerleri (ör. Bitcoin ~2,9 milyon TL) okunur kısalt: "2,92 mn".
  // Aksi halde "2.916.477" binlik ayracı yüzünden "2916" gibi okunuyor.
  function fmtPrice(n: number, decimals: number): string {
    if (n >= 1_000_000) return fmt(n / 1_000_000, 2) + ' mn';
    return fmt(n, decimals);
  }

  function setRow(key: string, value: number | null | undefined, change: number | null | undefined, prefix = '', decimals = 0) {
    const row = document.querySelector(`[data-row="${key}"]`);
    if (!row) return;
    const v = row.querySelector('[data-val]') as HTMLElement | null;
    const c = row.querySelector('[data-chg]') as HTMLElement | null;
    if (v && value != null && !Number.isNaN(value)) v.textContent = prefix + fmtPrice(value, decimals);
    if (c && change != null && !Number.isNaN(change)) {
      const up = change >= 0;
      c.textContent = (up ? '▲ ' : '▼ ') + Math.abs(change).toFixed(2) + '%';
      c.className = 'chg ' + (up ? 'up' : 'down');
    }
  }

  // Truncgil API'si zaman zaman KESİK/bozuk JSON döndürüyor; res.json() patlayınca
  // tüm TL değerleri güncellenmiyordu. İhtiyacımız olan alanlar (USD/GRA/XU100) hep
  // yanıtın başında olduğundan metinden regex ile çekiyoruz — kesik yanıtta da çalışır.
  function pick(text: string, key: string, prop: string): number | null {
    const m = text.match(new RegExp('"' + key + '"\\s*:\\s*\\{[^}]*?"' + prop + '"\\s*:\\s*(-?[0-9.]+)'));
    return m ? parseFloat(m[1]) : null;
  }

  async function loadTicker() {
    try {
      const res = await fetch('https://finans.truncgil.com/v4/today.json');
      const text = await res.text();
      setRow('bist', pick(text, 'XU100', 'Selling'), pick(text, 'XU100', 'Change'), '', 0);
      setRow('gold', pick(text, 'GRA', 'Selling'), pick(text, 'GRA', 'Change'), '₺', 0);
      setRow('usd', pick(text, 'USD', 'Selling'), pick(text, 'USD', 'Change'), '₺', 2);
      const upd = document.querySelector('[data-updated]');
      const dm = text.match(/"Update_Date"\s*:\s*"([^"]+)"/);
      if (upd && dm) upd.textContent = 'Güncel: ' + dm[1].slice(11, 16);
    } catch { /* canlı veri alınamadıysa placeholder kalır */ }

    try {
      const res = await fetch('https://api.coingecko.com/api/v3/simple/price?ids=bitcoin&vs_currencies=usd&include_24hr_change=true');
      const d = await res.json();
      setRow('btc', d.bitcoin?.usd, d.bitcoin?.usd_24h_change, '$', 0);
    } catch { /* yoksay */ }
  }

  loadTicker();
  // Fiyatları her 60 saniyede bir otomatik tazele (sekme görünürken).
  setInterval(() => {
    if (document.visibilityState === 'visible') loadTicker();
  }, 60000);
</script>
